{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brand-registry.dev/schemas/brand.schema.json",
  "title": "Brand Registry Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "slug",
    "status",
    "colours",
    "sources"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "domain": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["candidate", "verified", "needs_review", "deprecated", "conflicting_sources"]
    },
    "lastCheckedAt": { "type": "string", "format": "date" },
    "lastVerifiedAt": { "type": "string", "format": "date" },
    "notes": { "type": "string" },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "colours": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "hex", "role", "confidence", "sourceId"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "hex": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
          "role": {
            "type": "string",
            "enum": ["primary", "secondary", "accent", "neutral", "background", "text", "dark", "light", "unknown"]
          },
          "confidence": {
            "type": "string",
            "enum": ["official", "derived", "observed", "community"]
          },
          "sourceId": { "type": "string", "minLength": 1 },
          "validFrom": { "type": "string", "format": "date" },
          "validTo": { "type": "string", "format": "date" },
          "notes": { "type": "string" }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "url", "checkedAt"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "type": {
            "type": "string",
            "enum": ["brand_guidelines", "design_system", "press_kit", "logo_asset", "website", "manual_submission", "third_party_reference"]
          },
          "url": { "type": "string", "format": "uri" },
          "checkedAt": { "type": "string", "format": "date" },
          "hash": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "summary"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "summary": { "type": "string", "minLength": 1 },
          "pullRequest": { "type": "string" }
        }
      }
    }
  }
}
